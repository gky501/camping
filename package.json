{
  "name": "campsite-diary",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:cloudflare": "npm run build && wrangler pages dev dist",
    "db:create": "wrangler d1 create campsite-diary",
    "db:migrate:local": "wrangler d1 migrations apply campsite-diary --local",
    "db:migrate:remote": "wrangler d1 migrations apply campsite-diary --remote",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "wrangler": "^4.110.0"
  }
}
